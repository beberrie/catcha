<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="ph.edu.uscDCISMCatcha">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <queries>
        <package android:name="com.google.android.gms" />
        <package android:name="com.android.vending" />
        <package android:name="com.google.android.gsf" />

        <intent>
            <action android:name="com.google.android.gms.auth.service.START" />
        </intent>
        <intent>
            <action android:name="com.google.android.gms.common.service.START" />
        </intent>
        <intent>
            <action android:name="com.google.android.gms.auth.api.signin.SERVICE_CONFIG_UPDATED" />
        </intent>
    </queries>

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Catcha">
        <activity
            android:name=".ui.student.CampusProfile"
            android:exported="false" />
        <activity
            android:name=".ui.admin.AdminOrgListActivity"
            android:exported="false" />
        <activity
            android:name=".ui.admin.RegisterOrgActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".ui.admin.AdminHomeActivity"
            android:exported="false" />
        <activity
            android:name=".ui.org.OrgHomeActivity"
            android:exported="false" />
        <activity
            android:name=".ui.auth.SignupActivity"
            android:exported="false" />
        <activity
            android:name=".ui.auth.LoginActivity"
            android:exported="false" />
        <activity
            android:name=".ui.student.HomeActivity"
            android:exported="false" />
        <activity
            android:name=".ui.student.InterestsActivity"
            android:exported="false" />
        <activity
            android:name=".ui.student.EventDetailsActivity"
            android:exported="false" />
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.App.Starting">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>