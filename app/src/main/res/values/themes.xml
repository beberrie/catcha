<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base application theme -->
    <style name="Base.Theme.Catcha" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary Brand Color -->
        <item name="colorPrimary">@color/blue</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/soft_blue</item>
        <item name="colorOnPrimaryContainer">@color/white</item>

        <!-- Secondary Brand Color -->
        <item name="colorSecondary">@color/yellow</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="colorSecondaryContainer">@color/soft_yellow</item>
        <item name="colorOnSecondaryContainer">@color/black</item>

        <!-- Background and Surface Colors -->
        <item name="android:windowBackground">@color/white</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/black</item>

        <!-- Status Bar and Navigation Bar -->
        <item name="android:statusBarColor">@color/blue</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Default Font Family (Inter for normal text) -->
        <item name="android:fontFamily">@font/inter</item>

        <!-- TextInput Form Styling -->
        <item name="textInputStyle">@style/Widget.Catcha.TextInputLayout</item>
    </style>

    <!-- Custom Style for TextInputLayout -->
    <style name="Widget.Catcha.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/off_white</item>
        <item name="boxBackgroundMode">outline</item>
        <item name="boxStrokeColor">@color/text_input_stroke_color</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="hintTextColor">@color/blue</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.Catcha.SmallComponent</item>
    </style>

    <style name="Widget.Catcha.TextInputLayout.ExposedDropdownMenu" parent="Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu">
        <item name="boxBackgroundMode">outline</item>
        <item name="boxBackgroundColor">@color/off_white</item>
        <item name="boxStrokeColor">@color/text_input_stroke_color</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.Catcha.SmallComponent</item>
    </style>

    <!-- Reusable Button Styles -->
    <style name="Widget.Catcha.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:layout_width">319dp</item>
        <item name="android:layout_height">60dp</item>
        <item name="backgroundTint">@color/soft_yellow</item>
        <item name="android:elevation">5dp</item>
        <item name="android:fontFamily">@font/poppins</item>
        <item name="android:outlineAmbientShadowColor">@color/softlight_blue</item>
        <item name="android:outlineSpotShadowColor">@color/softlight_blue</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:textColor">@color/softlight_blue</item>
        <item name="android:textFontWeight">900</item>
        <item name="cornerRadius">25dp</item>
    </style>

    <style name="Widget.Catcha.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:layout_width">319dp</item>
        <item name="android:layout_height">60dp</item>
        <item name="android:fontFamily">@font/poppins</item>
        <item name="android:textColor">@color/blue</item>
        <item name="android:textFontWeight">900</item>
        <item name="cornerRadius">25dp</item>
        <item name="strokeColor">@color/blue</item>
        <item name="strokeWidth">2dp</item>
    </style>

    <!-- Reusable Filter Styles -->
    <style name="Widget.Catcha.Filter.Outlined" parent="Widget.Material3.Chip.Filter">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">22dp</item>
        <item name="android:gravity">center</item>
        <item name="chipBackgroundColor">@color/white</item>
        <item name="chipStrokeColor">@color/blue</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.Catcha.Filter</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
    </style>

    <!-- Custom Style for Buttons in Organizations Pages-->
    <style name="Widget.Catcha.Button.Join.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:layout_margin">12dp</item>
        <item name="android:textColor">@color/blue</item>
        <item name="android:textSize">14sp</item>
        <item name="backgroundTint">@color/white</item>
        <item name="strokeColor">@color/yellow</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="cornerRadius">22dp</item>
    </style>

    <!-- Style for Joined Button (Solid Yellow) -->
    <style name="Widget.Catcha.Button.Joined.Solid" parent="Widget.Material3.Button">
        <item name="android:layout_height">48dp</item>
        <item name="android:textColor">@color/blue</item>
        <item name="android:textSize">14sp</item>
        <item name="backgroundTint">@color/yellow</item>
        <item name="cornerRadius">24dp</item>
        <item name="android:fontFamily">@font/inter_bold</item>
    </style>

    <!-- Style for Member Status (Outlined Blue) -->
    <style name="Widget.Catcha.Button.Member.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:layout_height">48dp</item>
        <item name="android:textColor">@color/blue</item>
        <item name="android:textSize">14sp</item>
        <item name="strokeColor">@color/blue</item>
        <item name="strokeWidth">2dp</item>
        <item name="cornerRadius">24dp</item>
        <item name="android:fontFamily">@font/inter_bold</item>
    </style>

    <!-- Custom Styles for Tags using Chips -->
    <style name="Widget.Catcha.Chip.Tag.Blue" parent="Widget.Material3.Chip.Suggestion">
        <item name="chipBackgroundColor">@color/blue</item>
        <item name="android:textColor">@color/white</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.Catcha.SmallComponent</item>
        <item name="chipStrokeWidth">0dp</item>
        <item name="android:textSize">9sp</item>
    </style>

    <style name="Widget.Catcha.Chip.Tag.Yellow" parent="Widget.Material3.Chip.Suggestion">
        <item name="chipBackgroundColor">@color/yellow</item>
        <item name="android:textColor">@color/white</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.Catcha.SmallComponent</item>
        <item name="chipStrokeWidth">0dp</item>
        <item name="android:textSize">9sp</item>
        <item name="chipMinHeight">24dp</item>
    </style>

    <style name="ShapeAppearance.Catcha.SmallComponent" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerSize">22dp</item>
    </style>

    <style name="ShapeAppearance.Catcha.Filter" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerSize">20dp</item>
    </style>

    <style name="Theme.Catcha" parent="Base.Theme.Catcha" />

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/white</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/catcha_logo</item>
        <item name="postSplashScreenTheme">@style/Theme.Catcha</item>
    </style>

</resources>