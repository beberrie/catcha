<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="24dp">

            <!-- Banner Section -->
            <ImageView
                android:id="@+id/bannerImage"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:scaleType="centerCrop"
                android:src="@android:drawable/ic_menu_gallery"
                android:contentDescription="@string/org_banner_desc"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Profile Image (Overlapping Banner) -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/profileImage"
                android:layout_width="110dp"
                android:layout_height="110dp"
                android:background="@color/white"
                android:padding="3dp"
                android:scaleType="centerCrop"
                android:src="@android:drawable/ic_menu_gallery"
                android:contentDescription="@string/org_profile_image_desc"
                app:layout_constraintBottom_toBottomOf="@+id/bannerImage"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/bannerImage"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full" />

            <!-- Organization Name -->
            <TextView
                android:id="@+id/orgName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginHorizontal="24dp"
                android:fontFamily="@font/poppins_bold"
                android:gravity="center"
                android:text="@string/org_name_placeholder"
                android:textColor="@color/blue"
                android:textSize="18sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/profileImage" />

            <!-- Stats Row (Followers & Events) -->
            <LinearLayout
                android:id="@+id/statsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:orientation="horizontal"
                app:layout_constraintTop_toBottomOf="@+id/orgName">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvFollowersCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins_bold"
                        android:text="0"
                        android:textColor="@color/blue"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/org_followers_label"
                        android:textColor="@color/soft_blue"
                        android:textSize="12sp" />
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="35dp"
                    android:background="#DDDDDD" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvEventsCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins_bold"
                        android:text="0"
                        android:textColor="@color/blue"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/org_events_label"
                        android:textColor="@color/soft_blue"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Status Buttons Container -->
            <LinearLayout
                android:id="@+id/joinedStatusContainer"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="20dp"
                android:layout_marginHorizontal="24dp"
                android:orientation="horizontal"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@+id/statsContainer">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/joinedButton"
                    style="@style/Widget.Catcha.Button.Joined.Solid"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="@string/org_btn_joined"
                    app:elevation="0dp"
                    android:stateListAnimator="@null" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/memberButton"
                    style="@style/Widget.Catcha.Button.Member.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="@string/org_btn_member"
                    app:elevation="0dp"
                    android:stateListAnimator="@null" />
            </LinearLayout>

            <!-- Join Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/joinButton"
                style="@style/Widget.Catcha.Button.Join.Outlined"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="20dp"
                android:text="@string/org_btn_join"
                app:elevation="0dp"
                android:stateListAnimator="@null"
                app:layout_constraintTop_toBottomOf="@+id/statsContainer" />

            <androidx.constraintlayout.widget.Barrier
                android:id="@+id/actionButtonsBarrier"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:barrierDirection="bottom"
                app:constraint_referenced_ids="joinButton,joinedStatusContainer" />

            <!-- Events Section Header -->
            <TextView
                android:id="@+id/eventsHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="32dp"
                android:fontFamily="@font/poppins_bold"
                android:text="@string/org_events_header"
                android:textColor="@color/blue"
                android:textSize="18sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/actionButtonsBarrier" />

            <com.google.android.material.chip.Chip
                android:id="@+id/filterButton"
                style="@style/Widget.Catcha.Filter.Outlined"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="24dp"
                android:text="@string/org_filters_label"
                android:checkable="false"
                app:checkedIconVisible="false"
                app:elevation="0dp"
                app:chipIcon="@android:drawable/ic_menu_sort_by_size"
                app:chipIconSize="14dp"
                app:chipIconVisible="true"
                app:iconStartPadding="8dp"
                app:layout_constraintBottom_toBottomOf="@+id/eventsHeader"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@+id/eventsHeader" />

            <!-- Event Cards Container -->
            <LinearLayout
                android:id="@+id/eventsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical"
                android:paddingHorizontal="24dp"
                app:layout_constraintTop_toBottomOf="@+id/eventsHeader">
                <!-- Dynamic Event Cards will be added here -->
            </LinearLayout>

            <TextView
                android:id="@+id/tvNoEvents"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:padding="32dp"
                android:text="No events found for this organization."
                android:textColor="#AAAAAA"
                android:textSize="13sp"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/eventsContainer" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:padding="32dp"
                android:text="@string/org_limits_reached"
                android:textColor="#AAAAAA"
                android:textSize="13sp"
                app:layout_constraintTop_toBottomOf="@id/tvNoEvents" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Sticky Back Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/backButton"
        style="@style/Widget.Material3.Button.IconButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:padding="0dp"
        android:contentDescription="@string/org_back_desc"
        app:elevation="4dp"
        app:icon="@drawable/ic_back"
        app:iconGravity="textStart"
        app:iconPadding="0dp"
        app:iconSize="24dp"
        app:iconTint="@color/blue"
        app:backgroundTint="@color/white"
        app:cornerRadius="22dp"
        android:stateListAnimator="@null"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>