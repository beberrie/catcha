<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="#F7F7F7">


    <!-- Header -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:elevation="4dp">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">


            <ImageView
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/catcha_icon"
                android:scaleType="fitCenter" />


            <ImageView
                android:layout_width="0dp"
                android:layout_height="24dp"
                android:layout_weight="1"
                android:src="@drawable/catcha_typo"
                android:layout_marginStart="8dp"
                android:scaleType="fitStart" />


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textSize="13sp"
                android:textColor="#AAAAAA"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>


    <!-- Tab switcher -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:padding="10dp">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_tab_container"
            android:padding="3dp"
            android:orientation="horizontal">


            <Button
                android:id="@+id/btnTabNotifications"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="Notifications"
                android:textAllCaps="false"
                android:textSize="12sp"
                android:textColor="#F5C842"
                android:backgroundTint="#1D1D2E"
                android:stateListAnimator="@null" />


            <Button
                android:id="@+id/btnTabToken"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="Token"
                android:textAllCaps="false"
                android:textSize="12sp"
                android:textColor="#888888"
                android:background="@android:color/transparent"
                android:stateListAnimator="@null" />
        </LinearLayout>
    </LinearLayout>


    <!-- Content -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">


        <!-- NOTIFICATIONS TAB -->
        <LinearLayout
            android:id="@+id/layoutNotifications"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="visible">


            <!-- Mark all row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="10dp"
                android:paddingBottom="6dp"
                android:gravity="center_vertical">


                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Recommended for You"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A" />
            </LinearLayout>


            <!-- Scrollable Recommendations Area -->
            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent">


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">


                    <!-- Container for Organizations -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ORGANIZATIONS"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="#888888"
                        android:letterSpacing="0.05"
                        android:layout_marginBottom="8dp" />


                    <LinearLayout
                        android:id="@+id/layoutRecommendedOrgs"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="20dp" />


                    <!-- Container for Events -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="UPCOMING EVENTS"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="#888888"
                        android:letterSpacing="0.05"
                        android:layout_marginBottom="8dp" />


                    <LinearLayout
                        android:id="@+id/layoutRecommendedEvents"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="20dp" />


                </LinearLayout>
            </ScrollView>
        </LinearLayout>


        <!-- PUSH TOKEN TAB (Hidden by default) -->
        <ScrollView
            android:id="@+id/layoutPushToken"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">
            <!-- (Your existing token setup UI remains here) -->
        </ScrollView>
    </FrameLayout>
</LinearLayout>
