<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp">

    <!-- Main card -->
    <LinearLayout
        android:id="@+id/cardEventPost"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_card_notification"
        android:orientation="vertical">

        <!-- Header row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp">

            <!-- Org avatar -->
            <TextView
                android:id="@+id/tvOrgInitials"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:textSize="12sp"
                android:textColor="#F5C842"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/bg_avatar_dark"
                android:layout_marginEnd="10dp" />

            <!-- Org name + time -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvOrgName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvPostTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="#888888" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" · "
                        android:textSize="11sp"
                        android:textColor="#888888" />

                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:src="@drawable/ic_notification_bell"
                        android:scaleType="fitCenter" />
                </LinearLayout>
            </LinearLayout>

            <!-- 3-dot menu button (leader only) -->
            <ImageView
                android:id="@+id/btnPostMenu"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_dots"
                android:background="@drawable/bg_dots_btn"
                android:scaleType="center"
                android:padding="6dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:layout_marginEnd="4dp"
                android:visibility="gone" />

            <!-- X close button -->
            <ImageView
                android:id="@+id/btnClosePost"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_back_arrow"
                android:background="@drawable/bg_dots_btn"
                android:scaleType="center"
                android:padding="6dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Post body text -->
        <TextView
            android:id="@+id/tvPostBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="#1A1A1A"
            android:lineSpacingMultiplier="1.4"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="8dp" />

        <!-- Event card (amber) -->
        <LinearLayout
            android:id="@+id/layoutEventCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_event_card"
            android:orientation="vertical"
            android:padding="10dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="12dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvEventCardTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#412402"
                android:layout_marginBottom="2dp" />

            <TextView
                android:id="@+id/tvEventCardDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#854F0B" />
        </LinearLayout>
    </LinearLayout>

    <!-- Popup menu (positioned top-right, shown on 3-dot click) -->
    <LinearLayout
        android:id="@+id/layoutPopupMenu"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_popup_menu"
        android:orientation="vertical"
        android:elevation="8dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="52dp"
        android:layout_marginEnd="8dp"
        android:visibility="gone">

        <!-- Edit option -->
        <LinearLayout
            android:id="@+id/menuItemEdit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:background="@drawable/bg_menu_item_top">

            <!-- Edit icon circle -->
            <LinearLayout
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_edit_icon_circle"
                android:gravity="center"
                android:layout_marginEnd="10dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_edit"
                    android:scaleType="fitCenter" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Edit event"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Update details"
                    android:textSize="11sp"
                    android:textColor="#888888" />
            </LinearLayout>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="#E8E8E8" />

        <!-- Delete option -->
        <LinearLayout
            android:id="@+id/menuItemDelete"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:background="@drawable/bg_menu_item_bottom">

            <!-- Delete icon circle -->
            <LinearLayout
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_delete_icon_circle"
                android:gravity="center"
                android:layout_marginEnd="10dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_delete"
                    android:scaleType="fitCenter" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Delete event"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#E53935" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Remove permanently"
                    android:textSize="11sp"
                    android:textColor="#888888" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</FrameLayout>