<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ───────────────────────────────────────────── -->
        <!-- TOP APP BAR                                   -->
        <!-- ───────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#FFFFFF"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:orientation="horizontal">

            <!-- Logo -->
            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_launcher_foreground"
                android:layout_weight="1" />

            <!-- Icons -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="56dp"
                android:layout_marginLeft="200dp"
                android:background="#FFFFFF"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@android:drawable/ic_menu_search"
                    android:layout_marginEnd="14dp" />

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@android:drawable/ic_popup_reminder"
                    android:layout_marginEnd="14dp" />

                <!-- Avatar – replace src with your image -->
                <ImageView
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:src="@android:drawable/ic_menu_gallery"
                    android:scaleType="centerCrop"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ───────────────────────────────────────────── -->
        <!-- SUGGESTED FOR YOU                             -->
        <!-- ───────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:orientation="vertical"
            android:paddingTop="14dp"
            android:paddingBottom="14dp">

            <!-- Header row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins_bold"
                        android:text="Suggested for you"
                        android:textColor="@color/blue"
                        android:textSize="15sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"

                        android:layout_marginTop="2dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Orgs you might be interested in."
                            android:fontFamily="@font/inter"
                            android:textColor="@color/soft_blue"
                            android:textSize="12sp"
                            android:textAlignment="textStart"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="See all"
                            android:fontFamily="@font/inter_bold"
                            android:textColor="@color/soft_blue"
                            android:textSize="12sp"
                            android:textAlignment="textEnd"/>
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>

            <!-- Horizontally scrollable cards -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="12dp"
                android:clipToPadding="false"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- ───────────────────────────────────────────── -->
                    <!-- WHERE YOU INSERT THE SUGGEST CARD             -->
                    <!-- ───────────────────────────────────────────── -->

                </LinearLayout>
            </HorizontalScrollView>
        </LinearLayout>

        <!-- Spacer between sections -->
        <View
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:background="@color/soft_blue"
            />

        <!-- ───────────────────────────────────────────── -->
        <!-- ORGANIZATIONS SECTION                         -->
        <!-- ───────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="16dp">

            <!-- Section header row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Organizations"
                    android:fontFamily="@font/poppins_bold"
                    android:textColor="@color/blue"
                    android:textSize="16sp" />

                <!-- Filters button -->
                <LinearLayout
                    app:style="@style/Widget.Catcha.Filter.Outlined"
                    android:layout_width="wrap_content"
                    android:layout_height="25dp" >

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@android:drawable/ic_menu_sort_by_size"
                        android:layout_marginEnd="5dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Filters"
                        android:fontFamily="@font/inter"
                        android:textColor="@color/blue"
                        android:textSize="12sp" />

                </LinearLayout>
            </LinearLayout>

            <!-- ───────────────────────────────────────────── -->
            <!-- WHERE YOU INSERT THE CARD                     -->
            <!-- ───────────────────────────────────────────── -->

        </LinearLayout>

        <!-- ───────────────────────────────────────────── -->
        <!-- FOOTER                                        -->
        <!-- ───────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:padding="24dp"
            android:text="You've reached the limits :&lt;"
            android:textColor="#AAAAAA"
            android:textSize="13sp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>