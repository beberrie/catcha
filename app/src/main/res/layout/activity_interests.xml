<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:fitsSystemWindows="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="20dp"
            android:paddingBottom="220dp">

            <include layout="@layout/auth_layout_header" />

            <TextView
                android:id="@+id/tv_welcome"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="@string/interests_welcome"
                android:textColor="@color/text_dark"
                android:textSize="34sp"
                android:fontFamily="@font/poppins_bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/ivLogo" />

            <TextView
                android:id="@+id/tv_user_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/interests_user_name"
                android:textColor="@color/text_dark"
                android:textSize="34sp"
                android:fontFamily="@font/poppins_extrabold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_welcome" />

            <TextView
                android:id="@+id/tv_interests_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="@string/interests_label"
                android:textColor="@color/text_dark"
                android:textSize="18sp"
                android:fontFamily="@font/poppins_semibold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_user_name" />

            <TextView
                android:id="@+id/tv_interests_hint"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/interests_hint"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:alpha="0.7"
                android:fontFamily="@font/poppins"
                app:layout_constraintBaseline_toBaselineOf="@id/tv_interests_label"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/tv_interests_label" />

            <LinearLayout
                android:id="@+id/container_all_interests"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="vertical"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_interests_label">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_creative_arts"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginEnd="10dp"
                        android:text="@string/interests_creative_arts"
                        style="@style/Widget.InterestChip" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_tech_innovation"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="@string/interests_tech_innovation"
                        style="@style/Widget.InterestChip" />

                </LinearLayout>

                <com.google.android.flexbox.FlexboxLayout
                    android:id="@+id/sub_creative_arts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:visibility="gone"
                    app:flexWrap="wrap"
                    app:flexDirection="row"
                    app:alignItems="flex_start"
                    app:justifyContent="flex_start">

                    <com.google.android.material.chip.Chip android:layout_width="wrap_content" android:layout_height="36dp" android:layout_marginEnd="8dp" android:layout_marginBottom="8dp" android:text="@string/interests_music" style="@style/Widget.SubChip" />
                    <com.google.android.material.chip.Chip android:layout_width="wrap_content" android:layout_height="36dp" android:layout_marginEnd="8dp" android:layout_marginBottom="8dp" android:text="@string/interests_dance" style="@style/Widget.SubChip" />
                    <com.google.android.material.chip.Chip android:layout_width="wrap_content" android:layout_height="36dp" android:layout_marginEnd="8dp" android:layout_marginBottom="8dp" android:text="@string/interests_theater_acting" style="@style/Widget.SubChip" />
                    <com.google.android.material.chip.Chip android:layout_width="wrap_content" android:layout_height="36dp" android:layout_marginEnd="8dp" android:layout_marginBottom="8dp" android:text="@string/interests_photography" style="@style/Widget.SubChip" />
                    <com.google.android.material.chip.Chip android:layout_width="wrap_content" android:layout_height="36dp" android:layout_marginEnd="8dp" android:layout_marginBottom="8dp" android:text="@string/interests_visual_arts" style="@style/Widget.SubChip" />
                    <com.google.android.material.chip.Chip android:layout_width="wrap_content" android:layout_height="36dp" android:layout_marginEnd="8dp" android:layout_marginBottom="8dp" android:text="@string/interests_film_video" style="@style/Widget.SubChip" />

                </com.google.android.flexbox.FlexboxLayout>

                <com.google.android.flexbox.FlexboxLayout
                    android:id="@+id/sub_tech_innovation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:visibility="gone"
                    app:flexWrap="wrap"
                    app:flexDirection="row"
                    app:alignItems="flex_start"
                    app:justifyContent="flex_start">

                    <com.google.android.material.chip.Chip android:layout_width="wrap_content" android:layout_height="36dp" android:layout_marginEnd="8dp" android:layout_marginBottom="8dp" android:text="@string/interests_coding" style="@style/Widget.SubChip" />
                    <com.google.android.material.chip.Chip android:layout_width="wrap_content" android:layout_height="36dp" android:layout_marginEnd="8dp" android:layout_marginBottom="8dp" android:text="@string/interests_robotics" style="@style/Widget.SubChip" />
                    <com.google.android.material.chip.Chip android:layout_width="wrap_content" android:layout_height="36dp" android:layout_marginEnd="8dp" android:layout_marginBottom="8dp" android:text="@string/interests_ai" style="@style/Widget.SubChip" />

                </com.google.android.flexbox.FlexboxLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_academic_career"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginEnd="10dp"
                        android:text="@string/interests_academic_career"
                        style="@style/Widget.InterestChip" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_sports_wellness"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="@string/interests_sports_wellness"
                        style="@style/Widget.InterestChip" />

                </LinearLayout>

                <com.google.android.flexbox.FlexboxLayout
                    android:id="@+id/sub_academic_career"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:visibility="gone"
                    app:flexWrap="wrap"
                    app:flexDirection="row"
                    app:alignItems="flex_start"
                    app:justifyContent="flex_start">

                    <com.google.android.material.chip.Chip android:layout_width="wrap_content" android:layout_height="36dp" android:layout_marginEnd="8dp" android:layout_marginBottom="8dp" android:text="@string/interests_research" style="@style/Widget.SubChip" />
                    <com.google.android.material.chip.Chip android:layout_width="wrap_content" android:layout_height="36dp" android:layout_marginEnd="8dp" android:layout_marginBottom="8dp" android:text="@string/interests_entrepreneurship" style="@style/Widget.SubChip" />
                    <com.google.android.material.chip.Chip android:layout_width="wrap_content" android:layout_height="36dp" android:layout_marginEnd="8dp" android:layout_marginBottom="8dp" android:text="@string/interests_public_speaking" style="@style/Widget.SubChip" />

                </com.google.android.flexbox.FlexboxLayout>

                <com.google.android.flexbox.FlexboxLayout
                    android:id="@+id/sub_sports_wellness"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:visibility="gone"
                    app:flexWrap="wrap"
                    app:flexDirection="row"
                    app:alignItems="flex_start"
                    app:justifyContent="flex_start">

                    <com.google.android.material.chip.Chip android:layout_width="wrap_content" android:layout_height="36dp" android:layout_marginEnd="8dp" android:layout_marginBottom="8dp" android:text="@string/interests_basketball" style="@style/Widget.SubChip" />
                    <com.google.android.material.chip.Chip android:layout_width="wrap_content" android:layout_height="36dp" android:layout_marginEnd="8dp" android:layout_marginBottom="8dp" android:text="@string/interests_volleyball" style="@style/Widget.SubChip" />
                    <com.google.android.material.chip.Chip android:layout_width="wrap_content" android:layout_height="36dp" android:layout_marginEnd="8dp" android:layout_marginBottom="8dp" android:text="@string/interests_yoga" style="@style/Widget.SubChip" />

                </com.google.android.flexbox.FlexboxLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_community_service"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="@string/interests_community_service"
                        style="@style/Widget.InterestChip" />

                </LinearLayout>

                <com.google.android.flexbox.FlexboxLayout
                    android:id="@+id/sub_community_service"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:visibility="gone"
                    app:flexWrap="wrap"
                    app:flexDirection="row"
                    app:alignItems="flex_start"
                    app:justifyContent="flex_start">

                    <com.google.android.material.chip.Chip android:layout_width="wrap_content" android:layout_height="36dp" android:layout_marginEnd="8dp" android:layout_marginBottom="8dp" android:text="@string/interests_volunteering" style="@style/Widget.SubChip" />
                    <com.google.android.material.chip.Chip android:layout_width="wrap_content" android:layout_height="36dp" android:layout_marginEnd="8dp" android:layout_marginBottom="8dp" android:text="@string/interests_advocacy" style="@style/Widget.SubChip" />
                    <com.google.android.material.chip.Chip android:layout_width="wrap_content" android:layout_height="36dp" android:layout_marginEnd="8dp" android:layout_marginBottom="8dp" android:text="@string/interests_charity" style="@style/Widget.SubChip" />

                </com.google.android.flexbox.FlexboxLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_faith_culture"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="@string/interests_faith_culture"
                        style="@style/Widget.InterestChip" />

                </LinearLayout>

                <com.google.android.flexbox.FlexboxLayout
                    android:id="@+id/sub_faith_culture"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:visibility="gone"
                    app:flexWrap="wrap"
                    app:flexDirection="row"
                    app:alignItems="flex_start"
                    app:justifyContent="flex_start">

                    <com.google.android.material.chip.Chip android:layout_width="wrap_content" android:layout_height="36dp" android:layout_marginEnd="8dp" android:layout_marginBottom="8dp" android:text="@string/interests_subcat1" style="@style/Widget.SubChip" />
                    <com.google.android.material.chip.Chip android:layout_width="wrap_content" android:layout_height="36dp" android:layout_marginEnd="8dp" android:layout_marginBottom="8dp" android:text="@string/interests_subcat2" style="@style/Widget.SubChip" />
                    <com.google.android.material.chip.Chip android:layout_width="wrap_content" android:layout_height="36dp" android:layout_marginEnd="8dp" android:layout_marginBottom="8dp" android:text="@string/interests_subcat3" style="@style/Widget.SubChip" />

                </com.google.android.flexbox.FlexboxLayout>

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <!-- Background Decoration Fixed to Bottom Right -->
    <ImageView
        android:id="@+id/iv_catcha_cat"
        android:layout_width="320dp"
        android:layout_height="320dp"
        android:src="@drawable/catcha_cat"
        android:contentDescription="@string/interests_cat_desc"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="-80dp"
        android:layout_marginBottom="-80dp" />

    <!-- Fixed Footer -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_continue"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:text="@string/interests_continue"
        android:textColor="@color/black"
        android:textSize="15sp"
        android:fontFamily="@font/poppins_medium"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:drawableEnd="@drawable/ic_arrow_right"
        android:drawablePadding="10dp"
        android:enabled="false"
        android:alpha="0.5"
        app:backgroundTint="@color/white"
        app:strokeColor="@color/black"
        app:strokeWidth="1.5dp"
        app:cornerRadius="24dp"
        android:layout_marginStart="20dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tv_skip"
        android:layout_marginBottom="6dp" />

    <TextView
        android:id="@+id/tv_skip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/interests_skip"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:fontFamily="@font/poppins"
        android:padding="4dp"
        android:clickable="true"
        android:focusable="true"
        android:layout_marginStart="20dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="24dp" />

</androidx.constraintlayout.widget.ConstraintLayout>