<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:paddingBottom="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/btnCancel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cancel"
                android:fontFamily="@font/inter"
                android:textColor="@color/black"
                android:textSize="14sp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/btnShowResults"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="Show (0)"
                android:fontFamily="@font/inter_bold"
                android:textColor="@color/black"
                android:textSize="14sp"
                android:clickable="true"
                android:focusable="true" />
        </RelativeLayout>

        <!-- Active Filters Row -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:id="@+id/activeFiltersContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipResetAll"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Reset all"
                    android:fontFamily="@font/inter"
                    android:textSize="11sp"
                    android:checkable="false"
                    app:checkedIconVisible="false"
                    app:chipBackgroundColor="@color/white"
                    app:chipStrokeColor="@color/blue"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.Catcha.Filter" />
                <!-- Dynamic tags will be added here via Java -->

            </LinearLayout>
        </HorizontalScrollView>

        <!-- Status Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Status"
            android:fontFamily="@font/poppins_bold"
            android:textColor="@color/black"
            android:textSize="16sp"
            android:layout_marginBottom="16dp" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/cgStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            app:singleSelection="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipUpcoming"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="UPCOMING"
                android:checkable="true"
                android:fontFamily="@font/inter"
                android:textSize="11sp"
                app:checkedIconVisible="false"
                app:chipBackgroundColor="@color/chip_background_selector"
                android:textColor="@color/chip_text_selector"
                app:chipStrokeColor="@color/yellow"
                app:chipStrokeWidth="1dp"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Catcha.Filter" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipOngoing"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ONGOING"
                android:checkable="true"
                android:fontFamily="@font/inter"
                android:textSize="11sp"
                app:checkedIconVisible="false"
                app:chipBackgroundColor="@color/chip_background_selector"
                android:textColor="@color/chip_text_selector"
                app:chipStrokeColor="@color/yellow"
                app:chipStrokeWidth="1dp"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Catcha.Filter" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipFinished"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FINISHED"
                android:checkable="true"
                android:fontFamily="@font/inter"
                android:textSize="11sp"
                app:checkedIconVisible="false"
                app:chipBackgroundColor="@color/chip_background_selector"
                android:textColor="@color/chip_text_selector"
                app:chipStrokeColor="@color/yellow"
                app:chipStrokeWidth="1dp"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Catcha.Filter" />

        </com.google.android.material.chip.ChipGroup>

        <!-- Time Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Time"
            android:fontFamily="@font/poppins_bold"
            android:textColor="@color/black"
            android:textSize="16sp"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilStartTime"
                style="@style/Widget.Catcha.TextInputLayout.ExposedDropdownMenu"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:hintEnabled="false">

                <AutoCompleteTextView
                    android:id="@+id/atvStartTime"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:text=""
                    android:textSize="12sp"
                    android:fontFamily="@font/inter"
                    android:textColor="@color/black" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="to"
                android:layout_marginHorizontal="12dp"
                android:fontFamily="@font/inter"
                android:textColor="@color/black"
                android:textSize="14sp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilEndTime"
                style="@style/Widget.Catcha.TextInputLayout.ExposedDropdownMenu"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:hintEnabled="false">

                <AutoCompleteTextView
                    android:id="@+id/atvEndTime"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:text=""
                    android:textSize="12sp"
                    android:fontFamily="@font/inter"
                    android:textColor="@color/black" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <Button
            android:id="@+id/btnSetTime"
            style="@style/Widget.Catcha.Button.Join.Outlined"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="20dp"
            android:text="Set Time"
            android:textSize="14sp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>